{
  "name": "todo-list-clever",
  "version": "1.0.0",
  "description": "A todo list application built with Fastify.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "npm run build:ts && node dist/server.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "node --watch-path=dist dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "typebox": "^1.1.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "fastify-tsconfig": "^3.0.0",
    "prisma": "^7.6.0",
    "ts-node": "^10.4.0",
    "typescript": "~5.9.2"
  }
}